@model List<PizzaApp.Models.Order>

<h2>Orders</h2>

@foreach (var order in Model)
{
    <div class="card mb-4 p-3 shadow-sm">

        <h4>Order #@order.Id</h4>

        <p><strong>User:</strong> @order.UserName</p>

        <p>
            <strong>Status:</strong>
            <span class="badge
                @(order.Status == "Pending" ? "bg-warning" :
                                    order.Status == "Preparing" ? "bg-info" :
                                    "bg-success")">
                @order.Status
            </span>
        </p>

        <p><strong>Date:</strong> @order.CreatedAt.ToString("dd.MM.yyyy HH:mm")</p>

        @if (User.IsInRole("Admin"))
        {
            <div class="d-flex gap-2 mb-2">
                <form asp-action="UpdateStatus" method="post">
                    <input type="hidden" name="id" value="@order.Id" />

                    <button name="status" value="Preparing" class="btn btn-warning btn-sm"
                        @(order.Status == "Preparing" ? "disabled" : "")>
                        Preparing
                    </button>

                    <button name="status" value="Delivered" class="btn btn-success btn-sm"
                        @(order.Status == "Delivered" ? "disabled" : "")>
                        Delivered
                    </button>
                </form>

            </div>
        }
        @if (User.IsInRole("Admin"))
        {
            <form asp-action="Delete" method="post" style="display:inline;">
                <input type="hidden" name="id" value="@order.Id" />

                <button type="submit" class="btn btn-danger btn-sm"
                        onclick="return confirm('Are you sure you want to delete this order?');">
                    Delete
                </button>
            </form>
        }

        <table class="table mt-2">
            <thead>
                <tr>
                    <th>Pizza</th>
                    <th>Quantity</th>
                    <th>Total</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in order.Items)
                {
                    <tr>
                        <td>@item.Pizza?.Name</td>
                        <td>@item.Quantity</td>
                        <td>@($"{item.Price * item.Quantity:F2}€")</td>
                    </tr>
                }
            </tbody>
        </table>

        <h5>Total: @order.TotalPrice.ToString("F2")€</h5>

    </div>
}