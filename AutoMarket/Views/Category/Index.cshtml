@model IEnumerable<PizzaApp.Models.Category>

@{
    ViewData["Title"] = "Categories";
}

<h2 class="mb-3">Categories</h2>

@if (User.IsInRole("Admin"))
{
    <a class="btn btn-primary mb-3" asp-action="Create">Create Category</a>
}

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>
                Name
            </th>
            <th style="width:200px;">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @item.Name
                </td>
                <td>

                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm me-1">
                            Edit
                        </a>

                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm me-1">
                            Details
                        </a>

                        <form asp-action="Delete" method="post" style="display:inline;">
                            <input type="hidden" name="id" value="@item.Id" />
                            <button class="btn btn-danger btn-sm">
                                Delete
                            </button>
                        </form>
                    }

                </td>
            </tr>
        }
    </tbody>
</table>